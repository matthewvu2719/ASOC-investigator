# OpenAI (investigator + judge agents, and RAG embeddings — all read this
# automatically via ChatOpenAI / OpenAIEmbeddings)
OPENAI_API_KEY=

# Google Gemini (only needed if you swap the judge back to Gemini — see
# agents/judge.py; unused by default)
GOOGLE_API_KEY=

# Supabase (RAG store for prior incidents; Postgres + pgvector)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Threat intel (threat_intel_lookup tool — reputation, geolocation, and
# campaign context in one call; leave both unset to use the deterministic
# mock instead)
VIRUSTOTAL_API_KEY=
OTX_API_KEY=

# Sandbox / file detonation (detonate_file tool — real Hybrid Analysis
# submit+poll integration; leave unset to use the deterministic mock instead)
HYBRID_ANALYSIS_API_KEY=
